# BloomsBuilder Environment Configuration
# Copy this file to .env and fill in your values

# AI API Key (Anthropic Claude)
# Get your key from: https://console.anthropic.com/
# If not set, the app will use realistic mock data for generation
AI_API_KEY=your_anthropic_api_key_here

# Optional: Change the AI model used for generation
# Default: claude-haiku-4-5-20251001 (fast and cost-effective)
AI_MODEL=claude-haiku-4-5-20251001

# Application settings (optional)
APP_TITLE=BloomsBuilder
DEBUG=false
